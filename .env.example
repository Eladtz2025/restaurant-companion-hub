# =============================================================================
# Restaurant OS — Environment Variables
# =============================================================================
# העתק קובץ זה ל-`.env.local` לפיתוח מקומי, או הזן ערכים ב-Vercel ל-staging/production.
# 
# ⚠️  אל תעלה את `.env.local` ל-Git. אסור! הוא ב-`.gitignore`.
# 
# כל ערך מסומן ב:
#   [REQUIRED]    — חובה. האפליקציה לא תרוץ בלי זה.
#   [OPTIONAL]    — לא חובה ב-V1. ייתכן שדרוש בפיצ׳ר ספציפי.
#   [PROD ONLY]   — חובה רק בייצור. בפיתוח אפשר לדלג.
#   [DEV ONLY]    — רק לפיתוח מקומי.
# =============================================================================


# -----------------------------------------------------------------------------
# APP CORE
# -----------------------------------------------------------------------------

# [REQUIRED] שם ציבורי של האפליקציה
NEXT_PUBLIC_APP_NAME="Restaurant OS"

# [REQUIRED] URL ציבורי של האפליקציה. בפיתוח: localhost. בייצור: domain.
# Local: http://localhost:3000
# Staging: https://staging.app.example.com
# Production: https://app.example.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# [REQUIRED] סוד לחתימת JWT, cookies, וכו'. צור עם:
# openssl rand -base64 32
NEXTAUTH_SECRET=""

# [REQUIRED] מפתח encryption לשדות רגישים ברמת application (לא DB).
# 32 bytes בדיוק. צור עם:
# openssl rand -hex 32
APPLICATION_ENCRYPTION_KEY=""

# [REQUIRED] סביבה. "development" | "staging" | "production"
NEXT_PUBLIC_ENV="development"


# -----------------------------------------------------------------------------
# SUPABASE — Backend platform (DB, Auth, Storage, Edge Functions)
# -----------------------------------------------------------------------------
# מקור: https://supabase.com/dashboard/project/{project}/settings/api

# [REQUIRED] URL של הפרויקט
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"

# [REQUIRED] Anonymous public key. בטוח לחשיפה ב-frontend.
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# [REQUIRED] Service role key. ⚠️  סודי ביותר! עוקף RLS!
# רק ב-Edge Functions וב-server-side. לעולם לא ב-frontend.
SUPABASE_SERVICE_ROLE_KEY=""

# [REQUIRED] JWT secret של Supabase. לחתימת JWTs מותאמים אישית.
SUPABASE_JWT_SECRET=""

# [DEV ONLY] DB connection string לכלים כמו Drizzle או pgTAP.
# מקור: Supabase Dashboard → Settings → Database → Connection string (Direct)
DATABASE_URL="postgresql://postgres:password@localhost:54322/postgres"

# [DEV ONLY] Pooler connection (ל-serverless). Transaction mode חובה עם RLS.
DATABASE_POOL_URL="postgresql://postgres:password@localhost:54329/postgres"


# -----------------------------------------------------------------------------
# AI PROVIDERS
# -----------------------------------------------------------------------------

# [REQUIRED] Anthropic — מודל ראשי (Claude)
# מקור: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# [REQUIRED] Google AI — OCR (Gemini)
# מקור: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=""

# [OPTIONAL] OpenAI — fallback chain
# מקור: https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# [REQUIRED] Default daily AI budget per tenant ב-cents. ניתן לדריסה per tenant.
DEFAULT_AI_BUDGET_DAILY_CENTS="500"


# -----------------------------------------------------------------------------
# INNGEST — Background jobs
# -----------------------------------------------------------------------------
# מקור: https://app.inngest.com/env/production/manage/keys

# [REQUIRED] Event key — שליחת events ל-Inngest
INNGEST_EVENT_KEY=""

# [REQUIRED] Signing key — אימות webhook callbacks
INNGEST_SIGNING_KEY=""

# [DEV ONLY] Inngest Dev Server URL (default localhost:8288)
INNGEST_DEV_SERVER_URL="http://localhost:8288"


# -----------------------------------------------------------------------------
# OBSERVABILITY
# -----------------------------------------------------------------------------

# Sentry — Error tracking
# מקור: https://sentry.io/settings/{org}/projects/{project}/keys/

# [PROD ONLY] DSN — נשלח ל-frontend, פחות רגיש
NEXT_PUBLIC_SENTRY_DSN=""

# [PROD ONLY] Auth token — לעלאת source maps ב-CI
SENTRY_AUTH_TOKEN=""

# [PROD ONLY] Org slug
SENTRY_ORG=""

# [PROD ONLY] Project slug
SENTRY_PROJECT="restaurant-os"


# PostHog — Product analytics
# מקור: https://app.posthog.com/project/settings

# [PROD ONLY] Public API key
NEXT_PUBLIC_POSTHOG_KEY=""

# [PROD ONLY] Host (default: app.posthog.com)
NEXT_PUBLIC_POSTHOG_HOST="https://eu.posthog.com"


# Axiom — Structured logs
# מקור: https://app.axiom.co/{org}/settings/api-tokens

# [PROD ONLY] API token
AXIOM_TOKEN=""

# [PROD ONLY] Dataset name
AXIOM_DATASET="restaurant-os"

# [PROD ONLY] Org ID
AXIOM_ORG_ID=""


# -----------------------------------------------------------------------------
# STRIPE — Billing (Phase 10)
# -----------------------------------------------------------------------------
# מקור: https://dashboard.stripe.com/apikeys
# 
# הערה: Stripe לא חובה ב-V1 (פיילוט). מתחיל ב-Phase 10.

# [OPTIONAL] Publishable key (frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# [OPTIONAL] Secret key (backend)
STRIPE_SECRET_KEY=""

# [OPTIONAL] Webhook signing secret
# מקור: Stripe Dashboard → Webhooks → endpoint
STRIPE_WEBHOOK_SECRET=""


# -----------------------------------------------------------------------------
# EMAIL — Transactional email
# -----------------------------------------------------------------------------
# בחר Resend או SendGrid או AWS SES. מומלץ Resend לפשטות.

# [REQUIRED] Resend API key
# מקור: https://resend.com/api-keys
RESEND_API_KEY=""

# [REQUIRED] From address — domain מאומת
EMAIL_FROM="Restaurant OS <noreply@yourdomain.com>"

# [REQUIRED] Reply-to address
EMAIL_REPLY_TO="support@yourdomain.com"


# -----------------------------------------------------------------------------
# SMS / WhatsApp (Phase 8 — לא חובה ב-V1)
# -----------------------------------------------------------------------------

# [OPTIONAL] Twilio (אם משתמשים ב-SMS)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# [OPTIONAL] WhatsApp Business API
WHATSAPP_API_KEY=""
WHATSAPP_PHONE_NUMBER_ID=""


# -----------------------------------------------------------------------------
# SCRAPING / PLAYWRIGHT
# -----------------------------------------------------------------------------

# [PROD ONLY] User-Agent קבוע ל-scrapers. לא לשנות בלי חשיבה.
SCRAPER_USER_AGENT="Mozilla/5.0 (Macintosh; Intel Mac OS X 14_0) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/17.0 Safari/605.1.15"

# [PROD ONLY] Timeout בכל פעולת Playwright
SCRAPER_TIMEOUT_MS="60000"

# [PROD ONLY] Max retries לפני ש-job מסומן failed
SCRAPER_MAX_RETRIES="3"


# -----------------------------------------------------------------------------
# RATE LIMITING — Upstash Redis
# -----------------------------------------------------------------------------
# מקור: https://console.upstash.com/redis/{db}
# 
# רק ב-production. בפיתוח Vercel KV mock עובד.

# [PROD ONLY] Upstash REST URL
UPSTASH_REDIS_REST_URL=""

# [PROD ONLY] Upstash REST token
UPSTASH_REDIS_REST_TOKEN=""


# -----------------------------------------------------------------------------
# INTEGRATION SECRETS (אם יש API keys גלובליים)
# -----------------------------------------------------------------------------
# הערה: רוב ה-credentials של אינטגרציות (Tabit/OnTopo username/password וכו')
# נשמרות per-tenant ב-Supabase Vault, **לא כאן**.

# [OPTIONAL] Sumit — אם יש מפתח global, אחרת per-tenant
SUMIT_API_BASE_URL="https://api.sumit.co.il"

# [OPTIONAL] Marketman — אם יש מפתח global
MARKETMAN_API_BASE_URL="https://api.marketman.com/v3"


# -----------------------------------------------------------------------------
# FEATURE FLAGS — local override
# -----------------------------------------------------------------------------
# בייצור, feature flags באים מ-PostHog. במקומי אפשר לדרוס:

# [DEV ONLY] הפעלת AI editor (Phase 5)
NEXT_PUBLIC_FEATURE_AI_EDITOR="true"

# [DEV ONLY] הפעלת forecast מתקדם (Phase 7)
NEXT_PUBLIC_FEATURE_STATISTICAL_FORECAST="false"

# [DEV ONLY] הפעלת multi-tenant signup (Phase 10)
NEXT_PUBLIC_FEATURE_PUBLIC_SIGNUP="false"


# -----------------------------------------------------------------------------
# MISC
# -----------------------------------------------------------------------------

# [OPTIONAL] Slack webhook לאלרטים פנימיים
SLACK_ALERTS_WEBHOOK_URL=""

# [OPTIONAL] Sentry environment override
SENTRY_ENVIRONMENT="development"

# [DEV ONLY] Verbose logging
DEBUG="false"


# =============================================================================
# QUICK START — הרצה ראשונה במקומי
# =============================================================================
# 
# 1. צור פרויקט Supabase: https://supabase.com/dashboard/projects
#    → העתק URL, anon key, service role key.
#    → המסכים בהמשך.
# 
# 2. צור חשבונות בשירותים החיצוניים (חינם להתחלה):
#    - Anthropic Console
#    - Google AI Studio
#    - Inngest
#    - (Sentry, PostHog, Axiom — אופציונלי בפיתוח)
# 
# 3. צור secrets:
#    openssl rand -base64 32     # NEXTAUTH_SECRET
#    openssl rand -hex 32        # APPLICATION_ENCRYPTION_KEY
# 
# 4. הרץ:
#    pnpm install
#    supabase start          # מריץ Postgres + Auth + Storage local
#    supabase db reset       # מפעיל migrations + seed
#    pnpm dev                # מריץ Next.js
# 
# 5. פתח: http://localhost:3000
# 
# בעיה? בדוק שכל ה-[REQUIRED] משתנים מלאים.
# =============================================================================
